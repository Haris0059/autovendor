# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/olx_dashboard

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption (32-byte hex string for AES-256)
ENCRYPTION_KEY=change-me-to-a-64-char-hex-string-0000000000000000000000000000

# OLX API
OLX_API_BASE_URL=https://api.olx.ba

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
